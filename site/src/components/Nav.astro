---
let stars: number | null = null;
try {
  const res = await fetch("https://api.github.com/repos/known-life/life", {
    headers: { Accept: "application/vnd.github+json", "User-Agent": "known.life" },
  });
  if (res.ok) stars = ((await res.json()) as { stargazers_count?: number }).stargazers_count ?? null;
} catch { /* offline build — show the bare label */ }
const starLabel =
  stars == null || stars === 0 ? "GitHub"
  : stars >= 1000 ? `${(stars / 1000).toFixed(stars >= 10000 ? 0 : 1)}k`
  : `${stars}`;
---

<nav class="site-nav">
  <div class="site-nav-inner">
    <a href="/" class="brand">Life</a>
    <div class="nav-links">
      <a href="/#registry">Gene pool</a>
      <a href="/#model">The shape</a>
      <a href="/explore">Explore</a>
      <a href="/docs">Docs</a>
      <a href="/app">Sign in</a>
      <a href="https://github.com/known-life/life" target="_blank" rel="noopener" class="gh" aria-label={stars == null || stars === 0 ? "GitHub" : `GitHub — ${starLabel} stars`}>
        <svg class="gh-mark" width="17" height="17" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
        <span>{starLabel}</span>
      </a>
    </div>
  </div>
</nav>

<style>
  .site-nav {
    position: relative;
    z-index: 5;
  }
  .site-nav-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 30px 28px 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand {
    font-family: "Unbounded", system-ui, sans-serif;
    font-weight: 800;
    font-size: 20px;
    letter-spacing: -0.01em;
    display: flex;
    align-items: center;
    color: #22201f;
    text-decoration: none;
  }
  .nav-links {
    display: flex;
    gap: 26px;
    font-size: 14.5px;
    color: #6c6760;
    font-weight: 500;
  }
  .nav-links a {
    color: inherit;
    text-decoration: none;
  }
  .nav-links a:hover {
    color: #22201f;
  }
  .nav-links .gh {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #22201f;
    font-weight: 600;
  }
  .nav-links .gh .gh-mark {
    display: block;
  }
  @media (max-width: 640px) {
    .site-nav-inner {
      padding: 20px 18px 8px;
    }
    .brand {
      font-size: 18px;
    }
    .nav-links {
      gap: 16px;
    }
    .nav-links a:not(.gh) {
      display: none;
    }
  }
</style>
