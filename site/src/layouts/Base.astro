---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "A protocol for agent-legible repos — a git repo that remembers, acts, and evolves. Any coding agent can do it." } = Astro.props;
// Absolute URLs for the share card — crawlers (WhatsApp, iMessage, Slack)
// resolve nothing relative. og.jpg is the square blush-and-aviators card
// (source: scripts/og-card.html).
const site = "https://known.life";
const pageUrl = site + Astro.url.pathname;
const ogImage = `${site}/og.jpg`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:site_name" content="Life" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:secure_url" content={ogImage} />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="1200" />
  <meta property="og:image:alt" content="Mirrored aviator sunglasses reflecting a synthwave sunset, on a soft blush background" />
  {/* "summary" (not summary_large_image): the square og.jpg renders as the
      compact square card on Twitter/X, matching WhatsApp/iMessage. */}
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Unbounded:wght@600;700;800&family=Hanken+Grotesk:ital,wght@0,400;0,500;0,600;1,400&family=Spline+Sans+Mono:wght@400;500&family=Caveat:wght@600&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
