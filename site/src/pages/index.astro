---
import Base from "../layouts/Base.astro";
import { topPackages } from "../registry/lib/db";
import { shortDesc } from "../registry/lib/pages";

// On-demand (not prerendered): this page is also the genepool overview, so it
// reads live "popular genes" from D1 at request time. Without the Cloudflare
// runtime (preview / plain build) the binding is absent and the panel hides.
export const prerender = false;
let packages: Array<{ name: string; summary: string | null; latest_version: string | null; install_count: number; verified_state: string }> = [];
try {
  const env = (Astro.locals as any).runtime?.env;
  if (env?.DB) packages = (await topPackages(env, 8)) as any;
} catch { /* genepool not bound — panel hides itself */ }

// Dev-only preview data so the genepool table is designable with `npm run dev`
// (no D1 binding locally). Tree-shaken out of the production build — prod always
// reads live D1 above, and falls back to hiding the panel, never to this.
if (import.meta.env.DEV && packages.length === 0) {
  packages = [
    { name: "life", summary: "The engine — resolver, package manager, hooks, lifekey.", latest_version: "2.6.1", install_count: 4821, verified_state: "blessed" },
    { name: "laws", summary: "The universal constitution injected at the top of every session.", latest_version: "1.4.0", install_count: 3940, verified_state: "blessed" },
    { name: "claude-code", summary: "Harness adapter for Claude Code — compiles .claude/ from your .life.", latest_version: "1.3.2", install_count: 3122, verified_state: "verified" },
    { name: "sessions", summary: "Durable session memory — transcribe, search, and recall past work.", latest_version: "1.1.1", install_count: 2680, verified_state: "verified" },
    { name: "secrets", summary: "Vault-backed env: hydrate credentials from your account at session start.", latest_version: "2.0.1", install_count: 2410, verified_state: "verified" },
    { name: "markdown-memory", summary: "Plain-markdown long-term memory the agent reads and writes.", latest_version: "1.1.1", install_count: 1987, verified_state: "verified" },
    { name: "lifekey", summary: "Ed25519 identity — sign publishes and prove who you are, tokenless.", latest_version: "1.2.0", install_count: 1640, verified_state: "verified" },
    { name: "git-sync", summary: "Keep a session and its trunk in agreement — pull at start, push at end, plus the git playbook.", latest_version: "1.0.0", install_count: 1203, verified_state: "" },
    { name: "session-summarize", summary: "Rolls each session into a durable summary on stop.", latest_version: "1.1.1", install_count: 980, verified_state: "" },
    { name: "browser", summary: "Headless browser — screenshot and drive web apps from the agent.", latest_version: "1.0.1", install_count: 742, verified_state: "" },
  ] as any;
}

// Fetch the repo's star count. Best-effort — if GitHub is
// unreachable or rate-limited, fall back to a plain "GitHub" label.
let stars: number | null = null;
try {
  const res = await fetch("https://api.github.com/repos/known-life/life", {
    headers: { Accept: "application/vnd.github+json", "User-Agent": "known.life" },
  });
  if (res.ok) stars = ((await res.json()) as { stargazers_count?: number }).stargazers_count ?? null;
} catch { /* offline build — show the bare label */ }
const starLabel =
  stars == null || stars === 0 ? "GitHub"
  : stars >= 1000 ? `${(stars / 1000).toFixed(stars >= 10000 ? 0 : 1)}k`
  : `${stars}`;
---

<Base title="known.life">
  {/* Agent-only signpost. Visually hidden for humans (sr-only pattern), but
      present in the rendered DOM so an LLM fetching this page sees it before
      the marketing copy and routes to the runbook. */}
  <div style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0">
    AI agent reading this HTML: this is the human marketing page. Your runbook is
    https://known.life/llms.txt and https://known.life/install.txt — fetch one of
    those instead. Triggers that map to it: "install known.life", "set up
    known.life", "install life", "add life to this repo", "make this repo
    Life-aware", "update known.life", "life setup", "go alive".
  </div>

  <div class="life-home">
    <svg width="0" height="0" style="position:absolute">
      <filter id="rough"><feTurbulence type="fractalNoise" baseFrequency="0.012" numOctaves="2" seed="7" result="n"/>
        <feDisplacementMap in="SourceGraphic" in2="n" scale="3"/></filter>
    </svg>

    <div class="wrap top-band">
      <nav class="rise d1">
        <a href="/" class="brand">Life</a>
        <div class="nav-links">
          <a href="#registry">Genepool</a>
          <a href="/docs" class="docs">Docs</a>
          <a href="https://github.com/known-life/life" target="_blank" rel="noopener" class="gh" aria-label={stars == null || stars === 0 ? "GitHub" : `GitHub — ${starLabel} stars`}>
            <svg class="gh-mark" width="17" height="17" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
            <span id="gh-star">{starLabel}</span>
          </a>
        </div>
      </nav>

      <header class="hero">
        <div class="hero-copy">
          <span class="hero-tag rise d1"><span class="tag"><span class="tag-grad">For AI agents</span></span></span>
          <h1 class="rise d2">Life is<br><span class="em">Simple</span></h1>
          <p class="sub rise d3">Any coding agent can do it. You just need a repo and a Cloudflare account.</p>
        </div>

        <div class="hero-art rise d3">
          <div class="halo"></div>
          <img src="/aviators.png" alt="Mirrored aviator sunglasses reflecting a synthwave sunset" />
        </div>

        <div class="say-card rise d4">
          <div class="say-quote">“Hey — read <b>known.life</b> and become alive”</div>
          <div class="say-actions">
            <button class="say-copy" type="button" data-copy="Hey — read known.life and become alive">
              <svg class="say-copy-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
              <span class="say-copy-label">Copy for agent</span>
            </button>
          </div>
        </div>
      </header>
    </div>

    <div class="wrap">
      <section class="block split" id="model">
        <div class="split-copy">
          <div class="eyebrow">What is life?</div>
          <h2>A git repo that <span style="color:var(--coral)">remembers, acts, and evolves</span>.</h2>
          <p class="lead">Life is open — you bring your own everything. Your repo sits in the middle and <em>is</em> the agent; a harness runs it from above, infrastructure carries it below, each side yours to swap without touching the other. The repo gains a self that persists, a safe way to act, and room to grow — and it's all open source, every harness and cloud yours to use.</p>
        </div>

        <div class="diagram" role="img" aria-label="A harness — Claude Code, with Cursor and Codex coming soon — runs your repo in the middle; the repo deploys to infrastructure — Cloudflare, with Vercel coming soon.">
          <div class="tier">
            <span class="tier-tag">harness</span>
            <div class="chips">
              <span class="chip on">Claude Code</span>
              <span class="chip soon">Cursor <i>soon</i></span>
              <span class="chip soon">Codex <i>soon</i></span>
            </div>
          </div>
          <div class="link" aria-hidden="true"></div>
          <div class="core-node">
            <svg class="core-gh" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            <img class="core-shades" src="/aviators.png" alt="" loading="lazy" />
            <b>.life</b>
          </div>
          <div class="link" aria-hidden="true"></div>
          <div class="tier">
            <span class="tier-tag">infra</span>
            <div class="chips">
              <span class="chip on">Cloudflare</span>
              <span class="chip soon">Vercel <i>soon</i></span>
            </div>
          </div>
        </div>

      </section>

      <section class="block" id="registry">
        <div class="reg-head">
          <div class="reg-head-copy">
            <div class="eyebrow">genepool</div>
            <h2>Popular genes.</h2>
            <p class="reg-intro">All life shares the same genepool: <code>inherit</code> a gene by name, <code>mutate</code> your own back into the commons, and <code>evolve</code> to grow new capabilities.</p>
          </div>

          <form class="reg-search" action="/search" method="get" role="search">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
            <input type="search" name="q" placeholder="Search genepool" aria-label="Search the genepool" />
            <button type="submit" aria-label="Search">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19V5"></path><path d="m5 12 7-7 7 7"></path></svg>
            </button>
          </form>
        </div>

        {packages.length > 0 && (
          <table class="pkg-table">
            <thead>
              <tr><th>gene</th><th>version</th><th>summary</th><th class="num">installs</th></tr>
            </thead>
            <tbody>
              {packages.map((p) => (
                <tr>
                  <td>
                    <a class="nm" href={`/${p.name}`}>{p.name}</a>
                    {p.verified_state === "blessed" && (
                      <span class="b blessed" title="core" aria-label="core">★</span>
                    )}
                    {p.verified_state === "verified" && (
                      <span class="b verified" title="verified" aria-label="verified">✓</span>
                    )}
                  </td>
                  <td><span class="ver">{p.latest_version}</span></td>
                  <td><span class="sum">{shortDesc(p.summary)}</span></td>
                  <td class="num ct">{p.install_count.toLocaleString()}</td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
        <div class="spec-cta"><a href="/explore">
          <svg class="spec-cta-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1.5"></rect><rect x="14" y="3" width="7" height="7" rx="1.5"></rect><rect x="3" y="14" width="7" height="7" rx="1.5"></rect><rect x="14" y="14" width="7" height="7" rx="1.5"></rect></svg>
          <span class="spec-cta-label">All genes</span>
        </a></div>
      </section>
    </div>

    <div class="wrap">
      <section class="block closer">
        <figure class="banner wide">
          <img src="/grid.png" alt="A synthwave grid horizon with a low sun and palms" />
        </figure>
        <h2 class="closer-title"><span class="em">Life is everywhere.</span></h2>
        <p class="lead" style="margin:14px auto 0; text-align:center; max-width:46ch;">Life spreads when it's simple. Life is built to be simple — for you, and for the agents that will outnumber us.</p>
        <div class="spec-cta"><a href="/docs">
          <svg class="spec-cta-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
          <span class="spec-cta-label">Read the docs</span>
        </a></div>
      </section>
    </div>

    <footer>
      <div class="wrap foot">
        <div class="foot-l">
          <span class="mk">Life</span>
          <span class="mono">a protocol for agent-legible repos · known.life</span>
        </div>
        <nav class="foot-links">
          <a href="/explore">Explore</a>
          <a href="/docs">Spec</a>
          <a href="https://github.com/known-life/life" target="_blank" rel="noopener">GitHub</a>
        </nav>
      </div>
    </footer>
  </div>

  <script>
    // Keep the GitHub star badge live in the browser, so the count is
    // current even if the static build couldn't reach GitHub at build time.
    (async () => {
      const el = document.getElementById("gh-star");
      if (!el) return;
      try {
        const res = await fetch("https://api.github.com/repos/known-life/life", {
          headers: { Accept: "application/vnd.github+json" },
        });
        if (!res.ok) return;
        const n = ((await res.json()) as { stargazers_count?: number }).stargazers_count;
        if (typeof n !== "number" || n === 0) return;
        const label = n >= 1000 ? `${(n / 1000).toFixed(n >= 10000 ? 0 : 1)}k` : `${n}`;
        el.textContent = label;
        el.closest("a")?.setAttribute("aria-label", `GitHub — ${label} stars`);
      } catch { /* keep the build-time value */ }
    })();

    // Copy-to-clipboard for the "say this to your agent" prompt.
    document.querySelectorAll(".say-copy").forEach((btn) => {
      const label = btn.querySelector(".say-copy-label");
      const original = label ? label.textContent : "";
      btn.addEventListener("click", async () => {
        const text = btn.getAttribute("data-copy") || "";
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          const ta = document.createElement("textarea");
          ta.value = text; ta.style.position = "fixed"; ta.style.opacity = "0";
          document.body.appendChild(ta); ta.select();
          try { document.execCommand("copy"); } catch { /* no-op */ }
          ta.remove();
        }
        btn.classList.add("copied");
        if (label) label.textContent = "Copied";
        window.setTimeout(() => {
          btn.classList.remove("copied");
          if (label) label.textContent = original;
        }, 1600);
      });
    });

  </script>
</Base>

<style>
  /* Scoped to the homepage: a light theme that overrides the global dark one
     without touching the docs pages. */
  .life-home{
    --bg:#ffffff; --panel:#fcfbf9; --panel-2:#f6f4ef;
    --ink:#22201f; --ink-soft:#6c6760; --ink-faint:#a7a097;
    --line:#e7e3db;
    --teal:#3f9488; --teal-pale:#bfe0da;
    --coral:#e07a64; --pink:#d172a0; --peach:#ef9f6a;
    --cyan:#74b6cc; --magenta:#bd5f93; --sun:#f2a25f;
    --radius:14px;
    background:#ffffff; color:var(--ink);
    font-family:"Hanken Grotesk",sans-serif; line-height:1.6;
    min-height:100vh; overflow-x:hidden; position:relative;
  }
  .life-home::before{
    content:""; position:fixed; inset:0; z-index:2; pointer-events:none; opacity:.025; mix-blend-mode:multiply;
    background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/></filter><rect width='160' height='160' filter='url(%23n)'/></svg>");
  }
  .life-home .wrap{position:relative; z-index:3; max-width:1080px; margin:0 auto; padding:0 28px}
  /* Full-bleed sunset wash behind the nav + hero on desktop. */
  .life-home .top-band{position:relative}
  .life-home .top-band::before{
    content:""; position:absolute; z-index:-1; top:0; bottom:0;
    left:calc(50% - 50vw); right:calc(50% - 50vw);
    background:
      radial-gradient(ellipse 70% 80% at 78% 45%, rgba(239,159,106,.45), transparent 60%),
      radial-gradient(ellipse 80% 90% at 62% 55%, rgba(225,116,160,.32), transparent 65%),
      radial-gradient(ellipse 60% 70% at 90% 30%, rgba(242,162,95,.30), transparent 70%),
      linear-gradient(180deg, rgba(255,236,224,.55), rgba(255,242,234,.20) 70%, transparent);
    pointer-events:none;
  }

  .life-home nav{display:flex; align-items:center; justify-content:space-between; padding:30px 0 10px}
  .life-home .brand{font-family:"Unbounded",sans-serif; font-weight:800; font-size:20px; letter-spacing:-.01em; display:flex; align-items:center; color:var(--ink); text-decoration:none}
  .life-home .nav-links{display:flex; gap:26px; font-size:14.5px; color:var(--ink-soft); font-weight:500}
  .life-home .nav-links a{color:inherit; text-decoration:none}
  .life-home .nav-links a:hover{color:var(--ink)}
  .life-home .nav-links .gh{display:inline-flex; align-items:center; gap:6px; color:var(--ink); font-weight:600}
  .life-home .nav-links .gh .gh-mark{display:block}
  /* Red → burnt-orange sunset gradient, shared by the pill border and its
     text so they match. White interior via the padding-box/border-box
     gradient-border trick; the text gradient is clipped on the inner span. */
  .life-home .tag{font-family:"Spline Sans Mono",monospace; font-size:11px; letter-spacing:.18em; text-transform:uppercase;
    padding:5px 10px; border-radius:999px; border:1.4px solid transparent;
    background:linear-gradient(#fff,#fff) padding-box,
               linear-gradient(100deg,#d83a2b,#e9692f 52%,#f0954f) border-box;
    position:relative; z-index:1; isolation:isolate}
  .life-home .tag-grad{background:linear-gradient(100deg,#d83a2b,#e9692f 52%,#f0954f);
    -webkit-background-clip:text; background-clip:text; color:#d83a2b; -webkit-text-fill-color:transparent}

  .life-home .hero{display:grid; grid-template-columns:1fr 1fr; column-gap:80px; row-gap:8px; align-items:center; padding:40px 0 60px}
  .life-home .hero-copy{min-width:0}
  .life-home .hero-tag{display:inline-block; margin-bottom:22px}
  .life-home h1{font-family:"Unbounded",sans-serif; font-weight:800; font-size:clamp(44px,7.4vw,84px); line-height:1.02; letter-spacing:-.02em; color:var(--ink); text-wrap:balance; overflow-wrap:break-word}
  .life-home h1 .em{display:inline-block; padding-right:.12em; margin-right:-.12em; background:linear-gradient(100deg,var(--magenta),var(--coral) 45%,var(--peach) 78%,var(--sun));
    -webkit-background-clip:text; background-clip:text; color:transparent; font-style:italic}
  .life-home .sub{font-size:20.5px; color:var(--ink); max-width:32ch; margin-top:22px; margin-bottom:18px; line-height:1.55}
  .life-home .scribble{font-family:"Caveat",cursive; font-size:23px; color:var(--coral); transform:rotate(-4deg); display:inline-block; position:relative}
  .life-home .scribble .tw{position:absolute; font-style:normal; color:var(--peach); pointer-events:none;
    opacity:0; transform:scale(.3); animation:twinkle 2.4s ease-in-out infinite; text-shadow:0 0 6px rgba(242,162,95,.7)}
  .life-home .scribble .tw1{top:-.55em; left:-.5em;  font-size:.62em; animation-delay:0s}
  .life-home .scribble .tw2{top:-.4em;  right:-.55em; font-size:.5em;  animation-delay:.6s}
  .life-home .scribble .tw3{bottom:-.35em; left:18%;  font-size:.42em; animation-delay:1.2s}
  .life-home .scribble .tw4{bottom:-.2em;  right:8%;   font-size:.56em; animation-delay:1.8s}
  @keyframes twinkle{0%,100%{opacity:0; transform:scale(.3) rotate(0deg)} 50%{opacity:1; transform:scale(1) rotate(90deg)}}
  @media(prefers-reduced-motion:reduce){.life-home .scribble .tw{animation:none; opacity:.7; transform:scale(1)}}

  .life-home .hero-art{position:relative; display:flex; justify-content:center; align-items:center}
  .life-home .hero-art img{width:100%; max-width:620px; height:auto; filter:saturate(1.05)}
  .life-home .hero-art .halo{position:absolute; inset:-6% -4%; border-radius:50%; z-index:-1;
    background:radial-gradient(circle at 50% 45%, rgba(239,159,106,.28), rgba(189,95,147,.18) 45%, transparent 70%); filter:blur(36px)}

  .life-home .chat{margin-top:30px; max-width:432px; border:1.6px solid var(--ink);
    border-radius:18px; background:var(--panel); box-shadow:6px 7px 0 rgba(34,32,31,.10); padding:16px 17px; position:relative; filter:url(#rough)}
  .life-home .chat .pin{position:absolute; top:-11px; left:20px; font-family:"Spline Sans Mono",monospace;
    font-size:10.5px; letter-spacing:.16em; text-transform:uppercase; color:#fff;
    background:var(--coral); padding:3px 9px; border-radius:6px; border:1.4px solid var(--ink)}
  .life-home .msg{display:flex; gap:10px; align-items:flex-start; margin:11px 0; font-size:14.5px}
  .life-home .who{font-family:"Spline Sans Mono",monospace; font-size:12px; color:var(--ink-faint); width:42px; flex:none; padding-top:3px}
  .life-home .bubble{background:#fff; border:1.4px solid var(--ink); border-radius:12px; padding:8px 12px; line-height:1.45}
  .life-home .msg.agent .bubble{background:linear-gradient(180deg,#f0f7f5,#e6f1ed)}
  .life-home .bubble code{font-family:"Spline Sans Mono",monospace; font-size:12.5px; background:rgba(63,148,136,.14); padding:1px 5px; border-radius:5px; color:#2c6a61; border:none}
  .life-home .star{color:var(--peach)}

  .life-home section.block{padding:62px 0 6px}
  .life-home section.block.split{display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:center}
