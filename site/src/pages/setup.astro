---
import Base from "../layouts/Base.astro";

// Prerender — this page is pure client-side state. The server endpoints it
// talks to (/api/oauth/* and /api/setup/session) carry the dynamic bits.
export const prerender = true;
---

<Base title="Set up a .life — known.life/setup">
  <main class="setup">
    <div class="wrap">
      <header>
        <a href="/" class="brand">known.life</a>
        <h1>Set up a .life</h1>
        <p class="lede">
          One-page bootstrap. Sign in with GitHub, paste your Cloudflare token, get
          a single curl command. That curl, run anywhere, produces a fully provisioned
          .life — engine, harness, vault, lifekey, repo — without a second phase.
        </p>
      </header>

      <section id="step-begin" hidden>
        <h2>1. Sign in with GitHub</h2>
        <p>
          We'll request <code>repo</code> + <code>workflow</code> + <code>admin:public_key</code> + <code>read:user</code> —
          enough to push to one repo of your choosing (including its CI deploy
          workflow) and register your machine's public key on your
          <code>.keys</code>. No background access; the token expires in an
          hour and we never store it long-term.
        </p>
        <button id="begin" class="primary">Begin</button>
      </section>

      <section id="step-form" hidden>
        <h2>2. Cloudflare + repo</h2>
        <p id="form-greeting">Signed in as <code id="me"></code>.</p>
        <form id="setup-form" autocomplete="off">
          <label>
            <span>Cloudflare API token</span>
            <input id="cf_tok" type="password" required placeholder="paste the token from dash.cloudflare.com/profile/api-tokens" />
            <small>Permissions: Account → Workers Scripts, Workers KV Storage, D1, R2, Workers Routes. <a href="https://dash.cloudflare.com/profile/api-tokens" target="_blank" rel="noopener">Create one →</a></small>
          </label>
          <label>
            <span>Cloudflare account ID</span>
            <input id="cf_acc" type="text" required pattern="[a-f0-9]{32}" placeholder="32-char hex" />
            <small>Find it in the URL of any zone, or the right sidebar of dash.cloudflare.com.</small>
          </label>
          <label>
            <span>Repo slug</span>
            <input id="repo" type="text" required pattern="[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+" placeholder="owner/repo" />
            <small>An existing GitHub repo you can push to. The .life will be provisioned into it.</small>
          </label>
          <button type="submit" class="primary">Generate command</button>
          <p id="form-error" class="err" hidden></p>
        </form>
      </section>

      <section id="step-done" hidden>
        <h2>3. Run it</h2>
        <p>
          Paste this into any terminal with Node ≥ 18. The handle is single-use
          and expires in 10 minutes — re-generate if it sits unused.
        </p>
        <pre id="install-cmd"><code></code></pre>
        <p id="ci-warn" class="err" hidden>
          Heads-up: the CI deploy secrets could not be written to the repo, so
          deploys from GitHub Actions won't work until
          <code>CLOUDFLARE_API_TOKEN</code> and <code>CLOUDFLARE_ACCOUNT_ID</code>
          are added as repo Actions secrets. Setup itself is unaffected.
        </p>
        <p class="muted">
          Inside the script: cold-start (engine + harness adapter), then
          bootstrap (vault deploy, lifekey registration, repo init, baseline
          genome, harness sync). No further prompts.
        </p>
        <p><button id="copy" class="primary">Copy</button> <button id="reset" class="secondary">Start over</button></p>
      </section>
    </div>
  </main>
</Base>

<style>
  .setup { background: #fafafa; min-height: 100vh; padding: 4rem 1rem; }
  .wrap { max-width: 640px; margin: 0 auto; font: 16px/1.6 system-ui, sans-serif; color: #222; }
  header { border-bottom: 1px solid #ddd; padding-bottom: 2rem; margin-bottom: 2.5rem; }
  .brand { font-weight: 700; text-decoration: none; color: #666; font-size: 0.9rem; }
  h1 { font-size: 2rem; margin: 0.5rem 0; }
  h2 { font-size: 1.15rem; margin: 0 0 0.75rem; }
  .lede { color: #555; }
  section { margin-bottom: 3rem; }
  form { display: flex; flex-direction: column; gap: 1.25rem; }
  label { display: flex; flex-direction: column; gap: 0.25rem; }
  label > span { font-weight: 600; font-size: 0.9rem; }
  input { padding: 0.65rem 0.75rem; font: inherit; border: 1px solid #bbb; border-radius: 6px; background: white; }
  input:focus { outline: 2px solid #4a7fbd; outline-offset: -1px; }
  small { color: #666; font-size: 0.83rem; }
  small a { color: #4a7fbd; }
  button { padding: 0.7rem 1.2rem; font: inherit; border-radius: 6px; cursor: pointer; border: 1px solid #444; background: white; }
  button.primary { background: #222; color: white; }
  button.secondary { background: white; }
  button:disabled { opacity: 0.5; cursor: wait; }
  pre { background: #1e1e1e; color: #eaeaea; padding: 1rem; border-radius: 6px; overflow-x: auto; font: 14px/1.5 ui-monospace, monospace; }
  .err { color: #b00; }
  .muted { color: #666; font-size: 0.9rem; }
  code { font: 0.92em ui-monospace, monospace; background: #eee; padding: 0.1em 0.3em; border-radius: 3px; }
</style>

<script>
  // Vanilla DOM — no framework. The setup page is a tiny 3-step state machine
  // driven entirely by sessionStorage and URL params. State keys:
  //   life_setup_verifier  PKCE code_verifier we generated before bouncing to OAuth
  //   life_setup_jwt       The known.life JWT minted by /api/oauth/token
  //   life_setup_me        github_login on the JWT (cached for the form greeting)

  const $ = (sel: string) => document.querySelector(sel) as HTMLElement;
  const show = (id: string) => { const el = $(id); if (el) el.hidden = false; };
  const hide = (id: string) => { const el = $(id); if (el) el.hidden = true; };

  // --- PKCE helpers ---
  function randomB64Url(bytes: number): string {
    const b = new Uint8Array(bytes);
    crypto.getRandomValues(b);
    return b64url(b);
  }
  function b64url(buf: Uint8Array): string {
    let s = "";
    for (const x of buf) s += String.fromCharCode(x);
    return btoa(s).replace(/\+/g, "-").replace(/\//g, "_").replace(/=+$/, "");
  }
  async function s256(verifier: string): Promise<string> {
    const enc = new TextEncoder().encode(verifier);
    const buf = await crypto.subtle.digest("SHA-256", enc);
    return b64url(new Uint8Array(buf));
  }
  function decodeJwtSub(token: string): string | null {
    try {
      const p = token.split(".")[1];
      return JSON.parse(atob(p.replace(/-/g, "+").replace(/_/g, "/"))).sub ?? null;
    } catch { return null; }
  }

  // --- OAuth round-trip ---
  async function begin() {
    const verifier = randomB64Url(48);
    sessionStorage.setItem("life_setup_verifier", verifier);
    const challenge = await s256(verifier);
    const params = new URLSearchParams({
      response_type: "code",
      client_id: "known.life/setup",
      redirect_uri: location.origin + "/setup",
      scope: "repo,workflow,admin:public_key,read:user",
      state: randomB64Url(12),
      code_challenge: challenge,
      code_challenge_method: "S256",
    });
    location.href = "/api/oauth/authorize?" + params.toString();
  }

  async function exchangeCode(code: string) {
    const verifier = sessionStorage.getItem("life_setup_verifier");
    if (!verifier) throw new Error("missing PKCE verifier — did you reload mid-flow?");
    const res = await fetch("/api/oauth/token", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        grant_type: "authorization_code",
        code,
        redirect_uri: location.origin + "/setup",
        code_verifier: verifier,
      }),
    });
    const body = await res.json() as { access_token?: string; error?: string; error_description?: string };
    if (!res.ok || !body.access_token) throw new Error(body.error_description || body.error || "token exchange failed");
    sessionStorage.setItem("life_setup_jwt", body.access_token);
    const sub = decodeJwtSub(body.access_token);
    if (sub?.startsWith("github:")) sessionStorage.setItem("life_setup_me", sub.slice(7));
    sessionStorage.removeItem("life_setup_verifier");
    history.replaceState({}, "", "/setup");
  }

  // --- form submit ---
  async function submitForm(e: Event) {
    e.preventDefault();
    const errEl = $("#form-error") as HTMLElement;
    errEl.hidden = true;
    const jwt = sessionStorage.getItem("life_setup_jwt");
    if (!jwt) { errEl.textContent = "session lost — please sign in again"; errEl.hidden = false; return; }
    const submitBtn = (e.target as HTMLFormElement).querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = "Validating…";
    try {
      const res = await fetch("/api/setup/session", {
        method: "POST",
        headers: { "Content-Type": "application/json", Authorization: "Bearer " + jwt },
        body: JSON.stringify({
          cloudflare_api_token: ($("#cf_tok") as HTMLInputElement).value,
          cloudflare_account_id: ($("#cf_acc") as HTMLInputElement).value.toLowerCase(),
          repo_slug: ($("#repo") as HTMLInputElement).value,
        }),
      });
      const body = await res.json() as { install_cmd?: string; hint?: string; error?: string; ci_secrets_seeded?: boolean };
      if (!res.ok) throw new Error(body.hint || body.error || ("HTTP " + res.status));
      ($("#install-cmd") as HTMLElement).querySelector("code")!.textContent = body.install_cmd ?? "";
      ($("#ci-warn") as HTMLElement).hidden = body.ci_secrets_seeded !== false;
      hide("#step-form"); show("#step-done");
    } catch (err) {
      errEl.textContent = String(err instanceof Error ? err.message : err);
      errEl.hidden = false;
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Generate command";
    }
  }

  // --- step routing on load ---
  function route() {
    const url = new URL(location.href);
    const code = url.searchParams.get("code");
    if (code) {
      exchangeCode(code)
        .then(route)
        .catch((e) => { alert("OAuth exchange failed: " + e.message); location.href = "/setup"; });
      return;
    }
    if (sessionStorage.getItem("life_setup_jwt")) {
      const me = sessionStorage.getItem("life_setup_me");
      if (me) ($("#me") as HTMLElement).textContent = "@" + me;
      hide("#step-begin"); show("#step-form"); hide("#step-done");
    } else {
      show("#step-begin"); hide("#step-form"); hide("#step-done");
    }
  }

  $("#begin")?.addEventListener("click", begin);
  $("#setup-form")?.addEventListener("submit", submitForm);
  $("#copy")?.addEventListener("click", () => {
    const txt = ($("#install-cmd") as HTMLElement).querySelector("code")!.textContent || "";
    navigator.clipboard.writeText(txt);
  });
  $("#reset")?.addEventListener("click", () => {
    sessionStorage.removeItem("life_setup_jwt");
    sessionStorage.removeItem("life_setup_me");
    location.href = "/setup";
  });
  route();
</script>
